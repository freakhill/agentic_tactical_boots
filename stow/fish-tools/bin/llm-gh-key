#!/usr/bin/env fish

# managed-by: agentic_tactical_boots/install-fish-tools

set -l atb_cfg "$HOME/.config/agentic_tactical_boots/fish-tools.env"
if not test -f "$atb_cfg"
    echo "Tool install state not found: $atb_cfg" 1>&2
    echo "Run: scripts/install-fish-tools.fish install" 1>&2
    exit 1
end
source "$atb_cfg"
source "$ATB_REPO_ROOT/stow/fish-tools/lib/agentic_tactical_boots/dispatch.fish"; or exit 1
atb-dispatch source "scripts/llm-github-keys.fish" "llm-gh-key" $argv
