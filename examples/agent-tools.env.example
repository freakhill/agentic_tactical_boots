# Copy to examples/agent-tools.env and customize pinned versions.

# Enable npm CLIs only when you need them.
ENABLE_CLAUDE_CODE=false
ENABLE_OPENCODE=false

# Python stacks enabled by default.
ENABLE_CREWAI=true
ENABLE_PYDANTICAI=true
ENABLE_AG2=true

# Pin package coordinates for reproducible builds.
CLAUDE_CODE_NPM_PACKAGE=@anthropic-ai/claude-code
CLAUDE_CODE_VERSION=2.1.121

OPENCODE_NPM_PACKAGE=opencode-ai
OPENCODE_VERSION=1.14.28

CREWAI_VERSION=0.11.2
PYDANTIC_AI_VERSION=1.87.0
PYDANTIC_AI_HARNESS_VERSION=0.2.0
AG2_VERSION=0.12.1
